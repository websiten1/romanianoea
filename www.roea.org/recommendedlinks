	        		$('#sm-button-add-to-cart-'+e).removeClass('btn-3rd');        		
        		}
        		else
      			{
	        		$('#sm-button-add-to-cart-'+i).text('Add to cart');
	        		$('#sm-button-add-to-cart-'+i).addClass('btn-3rd');
	        		$('#sm-button-add-to-cart-'+i).removeClass('btn-3rd-inv');
	        		
	        		$('#sm-button-add-to-cart-'+e).text('Add to cart');
	        		$('#sm-button-add-to-cart-'+e).addClass('btn-3rd');
	        		$('#sm-button-add-to-cart-'+e).removeClass('btn-3rd-inv');
	        		
	        		q_sel.val(1);        				
      			}
        		// add item to cart
        		
        		// show popup for add to cart
        		/*
        		$('#sm_add_to_cart_div').SlickModals({
                popup_reopenClass: 'sm-1',
                popup_animation: 'slideRight',
                popup_position: 'bottomRight',
                popup_css: {
                    'padding': '40px',
