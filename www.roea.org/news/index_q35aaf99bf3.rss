function get_pubdate($news_item)
{
  if ($news_item['archive_type'] == "date")
  {
      $m = substr($news_item['current'], 5, 2);
      $d = substr($news_item['current'], 8, 2);
      $y = substr($news_item['current'], 0, 4);  
      $hr = substr($news_item['current_t'], 0, 2);  
      $mn = substr($news_item['current_t'], 3, 2);  	
               
      $pubdate = date(DATE_RFC2822, mktime ( (int)$hr, (int)$mn, (int)0, (int)$m, (int)$d, (int)$y ));
  }
  else
      $pubdate = date(DATE_RFC2822, $news_item['unix_last_update']);
  return $pubdate;

}


function news_get_description($news_items)
{
 // GET IMAGE IF EXISTS
 $imgquery = "select * from imgs where id={$news_items['image']}";
 $imgresult = mysqli_query($GLOBALS['connection'], $imgquery);
 if ($imgresult)
 {
   $img = mysqli_fetch_array($imgresult);
 }

if ($img['id1'])
{
		$img_src = display_image_href(
		    $img['id1'],
		    $img['archive1'],
		    $img['percent1'],
		    $img['width1'],
		    $img['height1'],
		    $img['border1'],
		    '',
		    0,
		    "left",
		    0,
		    5,
		    5
		);
		
		// ?? CRITICAL: strip quotes and whitespace
		$img_src = trim($img_src);
		$img_src = trim($img_src, '"');
		$img_src = trim($img_src, "'");
		
		// ensure absolute URL
		if (strpos($img_src, 'http') !== 0)
		{
		    $img_src = "https://".$_SERVER['HTTP_HOST'].$img_src;
		}

    return "<div><img border=\"{$img['border1']}\" hspace=\"5\" vspace=\"0\" align=\"left\" src=\"$img_src\">{$news_items['description']}</div>";
}
 else
   return $news_items['description'];
}



