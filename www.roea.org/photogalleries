        			$('#sm-cart-item-tr-'+i_e).fadeOut( timeout_length, "linear" );
        			$('#sm-cart-item-tr-header-'+i_e).fadeOut( timeout_length, "linear" );        			
        		}
        		else
      			{
      				if($('#sm-cart-item-tr-'+i_e).is(':animated')) {
       					$('#sm-cart-item-tr-'+i_e).stop().animate({opacity:'100'});
       					$('#sm-cart-item-tr-header-'+i_e).stop().animate({opacity:'100'});       					
      				}
      				$("[name="+i_e+"]").val(response.q_added);
      			}
      			
      			if  (response.total_items == 0)
      			{
      				$('#sm-cart-table').fadeOut( timeout_length, "linear" ); 
      				$('#green-proceed_to_check_out').fadeOut( timeout_length, "linear" ); 
      			}
      			else
      			{
      				if($('#sm-cart-table').is(':animated')) {
       					$('#sm-cart-table').stop().animate({opacity:'100'});  
       					$('#green-proceed_to_check_out').stop().animate({opacity:'100'});          					    					
      				}      				
      			}	
        			
        		
        		$('#sm-cart-amt-'+i_e).text(response.amount);
        		$('#sm-cart-qty-'+i_e).text(qty);       
        		$('.sm-cart-items_price').text(response.subtotal);          		 		
        		$('#sm-cart-amt-subtotal').text(response.subtotal);    
        		$('.sm-cart-number-of-items').text(response.total_items+items);  
        		$('#sm-cart-total_items').text(response.total_items);   
        		
						// Remove old header row
						$('#sm-cart-item-tr-header-' + i_e).remove();
						
						// Insert updated header row if qty > 0
						if (qty > 0 && response.item_details_header) {
						    $('#sm-ecomm-header-cart-tbody tr:first').after(response.item_details_header);
						}        		

						
						// max reached
						if (response.max_allowed_reached)
						{
							
							swal({
							  html:true,
							  title: "",
							  text: response.max_allowed_reason+"<br>"+response.item_name,
							  type: "info",
							  showCancelButton: false,
							  confirmButtonColor: "primary",
							  confirmButtonText: "Okay",
							  closeOnConfirm: false
							});			
						}

        		        		 		
        		              
					}
					else
					{														
							swal({
							  html:true,
							  title: "",
							  text: "We failed to update your cart.",
							  type: "error",
							  showCancelButton: false,
							  confirmButtonColor: "primary",
							  confirmButtonText: "Okay",
							  closeOnConfirm: false
							});	
					}                									  		

        },
	      error: function() 
	      {
					
				},
       timeout : 15000//timeout of the ajax call															  	
  });
			

}

