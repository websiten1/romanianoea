							if (qty_select) 
							{ 
								$('#sm-quantity-'+i).val(response.max_allowed);
							}
							else
							{
								q = $('#sm-quantity-'+e).val(response.max_allowed); 
							}							
							
						}

        		
        		// switch buttons
        		if ((response.item_details != "<div id=\"sm-cart-empty-msg\">Your cart is empty.</a>") && (response.item_details != ''))
        		{
	        		$('#sm-button-add-to-cart-'+i).text('View in cart');
	        		$('#sm-button-add-to-cart-'+i).addClass('btn-3rd-inv');
	        		$('#sm-button-add-to-cart-'+i).removeClass('btn-3rd');
	        		
